# Nemotron ASR systemd environment template.
#
# Copy to /etc/nemotron/asr.env for per-box overrides used by
# deploy/nemotron-asr.service and deploy/launch_single.sh. Nothing in this file
# is required for the unit to boot; launcher defaults are functional. systemd
# EnvironmentFile values are not shell-expanded, so use absolute paths when
# overriding path values.
#
# Links:
#   Unit: deploy/nemotron-asr.service
#   Launcher: deploy/launch_single.sh
#   Runbook/how: deploy/RUNBOOK.md
#   Rationale/why: deploy/DEPLOYMENT.md
#
# Troubleshooting:
#   Model download stall: journalctl -u nemotron-asr -f; check HF_HOME space,
#     outbound network, and Hugging Face cache permissions for user ubuntu.
#   GPU not visible: run nvidia-smi as ubuntu; torch must see CUDA or server.py
#     exits before binding.
#   /health never green: curl http://127.0.0.1:8080/health; the port binds only
#     after load_model(), so check model load and GPU errors in journald.
#   Restart loop: systemctl status nemotron-asr and journalctl -u nemotron-asr
#     show the launcher/server exit reason; RestartSec=5 only paces retries.
#   NeMo install failed: activate NEMOTRON_VENV and verify python can import
#     nemo.collections.asr from the editable install described in the runbook.

###############################################################################
# RECOMMENDED-EXPLICIT
###############################################################################

# Default: 12. Matches deploy/launch_single.sh and is not functionally required
# to boot, but setting it explicitly makes the admission cap visible in the
# running config. Provenance: 2026-05-24 admission-shedding validation; see
# deploy/DEPLOYMENT.md for why backlog count is the production signal.
NEMOTRON_ADMISSION_MAX_BACKLOG=12

###############################################################################
# OPTIONAL
###############################################################################

# Path overrides

# Default: /home/ubuntu/nemotron in the unit, $HOME/nemotron in the launcher.
# App checkout; pinned by the Phase 1 bootstrap/runbook layout.
# NEMOTRON_APP_DIR=/home/ubuntu/nemotron

# Default: /home/ubuntu/nemo-venv in the unit, $HOME/nemo-venv in the launcher.
# Python venv with torch, NeMo, and editable Nemotron install; pinned by
# ec2-bench/bootstrap.sh.
# NEMOTRON_VENV=/home/ubuntu/nemo-venv

# Default: nvidia/nemotron-speech-streaming-en-0.6b. Model id/path passed to the
# server; pinned by the production checkpoint used for Phase 1 validation.
# NEMOTRON_MODEL=nvidia/nemotron-speech-streaming-en-0.6b

# Default: /home/ubuntu/hf in the unit, $HOME/hf in the launcher. Hugging Face
# cache root; pinned by the bootstrap/runbook layout to keep model artifacts
# outside the repo.
# HF_HOME=/home/ubuntu/hf

# Network

# Default: 8080. Single backend port per box; pinned by the Phase 1 HAProxy plan.
# NEMOTRON_PORT=8080

# Default: 1. Right-context argument passed to server.py; pinned by the validated
# deploy/launch_multiproc.sh invocation and carried into launch_single.sh.
# NEMOTRON_RIGHT_CONTEXT=1

# Production optimization stack
#
# These defaults are lifted from deploy/launch_multiproc.sh:49-67 using canonical
# NEMOTRON_* names. They were validated under K=3+MPS; Phase 1 carries them into
# single-proc/no-MPS while DEPLOYMENT.md records the carry-over assumption.

# Default: 1. Enables the continuous streaming context; K=3+MPS validation stack.
# NEMOTRON_CONTINUOUS=1

# Default: 0. Finalizes immediately at endpoint; K=3+MPS low-latency validation.
# NEMOTRON_FINALIZE_SILENCE_MS=0

# Default: 200. Per-session warmup window in ms; K=3+MPS validation stack.
# NEMOTRON_WARMUP_MS=200

# Default: 1. Enables scheduler B=1 mode required by batching; K=3+MPS validation.
# NEMOTRON_SCHEDULER_B1=1

# Default: 1. Enables the batch scheduler path; K=3+MPS validation stack.
# NEMOTRON_BATCH_SCHED=1

# Default: 32. Batch-size ceiling; pinned by the max-parallelism sweep and used
# in the K=3+MPS validation stack.
# NEMOTRON_BATCH_MAX_SIZE=32

# Default: 8. Batch wait budget in ms; pinned by the max-parallelism sweep and
# used in the K=3+MPS validation stack.
# NEMOTRON_BATCH_MAX_WAIT_MS=8

# Default: 2. Model lanes per process; pinned by validation where >2 regressed.
# NEMOTRON_MODEL_LANES=2

# Default: 1. Enables batch barrier drain behavior; K=3+MPS validation stack.
# NEMOTRON_BATCH_BARRIER_DRAIN=1

# Default: 1. Keeps finalize work on the batched path; K=3+MPS validation stack.
# NEMOTRON_BATCH_FINALIZE=1

# Default: 1. Enables steady encoder CUDA graphs; K=3+MPS validation stack.
# NEMOTRON_ENCODER_CUDAGRAPH=1

# Default: 8. Steady encoder CUDA graph max batch; K=3+MPS validation stack.
# NEMOTRON_ENCODER_CUDAGRAPH_MAX_B=8

# Default: 1. Enables finalize encoder CUDA graphs; K=3+MPS validation stack.
# NEMOTRON_ENCODER_CUDAGRAPH_FINALIZE=1

# Default: 1. Uses one padded T_max finalize bucket; cloud-validated to reduce
# finalize graph memory while preserving full T coverage.
# NEMOTRON_ENCODER_CUDAGRAPH_FINALIZE_PADDED=1

# Default: 1. Skips redundant telemetry pre-syncs; 2026-05-24 tail-latency lever.
# NEMOTRON_SYNC_COMPRESS=1

# Default: 1. Prioritizes finalize lane work across sessions; 2026-05-24 tail
# validation bounds cross-session finalize head-of-line delay.
# NEMOTRON_FINALIZE_PRIORITY=1

# Advanced passthroughs from deploy/launch_multiproc.sh:57-67

# Default: unset/off. Enables finalize-path measurement and adds overhead; use
# only for diagnostics. Provenance: K=3+MPS measurement hook, not prod default.
# NEMOTRON_FINALIZE_PROFILE=1

# Default: 1 (enabled). Always-on rolling-latency stats via the /stats endpoint
# (vad_stop_to_sent_ms / fork_flush_wall_ms / vad_stop_recv_to_process_ms /
# lock_wait_ms / vad_stop_to_finalize_start_ms percentiles + active-session
# counts + admission counters). Cost is one deque append per finalize; no GPU
# work and no FINALIZE_PROFILE-style cuda_synchronize. Set to 0 to disable.
# NEMOTRON_STATS_ENABLED=1

# Default: 2048. Number of finalize samples retained in the /stats sliding
# window. Each sample is ~80 bytes — 2048 covers ~10min at conc=10. Increase
# for longer rolling horizons; bounded memory, O(1) append, O(N log N) on the
# /stats GET (sub-ms at 2k samples).
# NEMOTRON_STATS_WINDOW=2048

# Default: unset/off. Dumps Python thread stacks on SIGUSR1 for hang diagnosis;
# provenance: K=3+MPS diagnostic hook carried through the environment.
# NEMOTRON_FAULTHANDLER=1

# Default: unset by launcher; server default is 1000000000000.0 ms. Alternative
# admission age signal; 2026-05-24 validation found backlog count tracks overload.
# NEMOTRON_ADMISSION_MAX_READY_AGE_MS=1000000000000.0

# Default: unset by launcher; server default is 42. Finalize CUDA graph T-range
# trim fallback; padded T_max is the preferred validated memory lever.
# NEMOTRON_ENCODER_CUDAGRAPH_FINALIZE_T_MIN=42

# Default: unset by launcher; server default is 60. Finalize CUDA graph T-range
# trim fallback; padded T_max is the preferred validated memory lever.
# NEMOTRON_ENCODER_CUDAGRAPH_FINALIZE_T_MAX=60
